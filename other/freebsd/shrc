# the environment variable ENV is set to this file.
#
# see also sh(1), environ(7).
#

# file permissions: rwxr-xr-x
# umask	022
. $HOME/.profile

export PAGER=less
export EDITOR=micro
#PS1='${PWD##*/}→ '
set -o emacs

PS1="\w→ "


alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias h='fc -l'

# some aliases
alias j=jobs
alias m="$PAGER"
alias ll='ls -laFo'
alias l='ls -lo'
alias 'cd..'='cd ..'
alias cls='clear'
alias g='egrep -i'

# i can't stop using my fbsd aliases. please save me.
#alias pkg='sudo pkg'
alias pkg-i='sudo pkg inst'
alias pkg-r='sudo pkg remove'
alias pkg-inf='pkg info'
alias pkg-upg='sudo pkg upgrade'
alias pkg-upd='sudo pkg update'
alias pkg-s='pkg search'
alias mountlin='sudo mount -t ext2fs'
alias service='sudo service'
alias ch!=$HOME/.icewm/scripts/blued/ch.sh
alias kldload='sudo kldload'
alias terry='fortune terry'
alias troll='fortune troll'
alias ken='fortune ken'
alias rob='fortune rob'
alias aiju='fortune aiju'

# be paranoid :3
alias cp='cp -ip'
alias mv='mv -i'
alias mv!="/bin/mv"
alias cp!="/bin/cp"

# # csh like history on arrow up and down
bind ^[[A ed-search-prev-history
bind ^[[B ed-search-next-history

# # ctrl+arrow allow to jump from words to words
bind "\\e[1;5C" em-next-word
bind "\\e[1;5D" ed-prev-word
alias history='fc -l'

# Fix home/del for mobaxterm
bind ^[[5~ ed-move-to-beg
bind ^[[6~ ed-move-to-end
