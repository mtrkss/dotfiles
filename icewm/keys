key "Super+x"            	urxvt
key "Super+Enter"           ~/.icewm/keyscript s-enter
key "Print"            		~/.icewm/keyscript print
key "Super+Print"           ~/.icewm/keyscript s-print
key "Super+m"           	rhythmbox
key "Super+f"				firefox
key "Super+c"				~/.icewm/keyscript s-c
key "Super+s"				xmag


key "XF86AudioLowerVolume"  amixer sset Master 5%-
key "XF86AudioRaiseVolume"  amixer sset Master 5%+
key "XF86AudioMute"         amixer sset Master toggle
key "XF86Search"            xdg-open https://www.duckduckgo.com
key "XF86Calculator"        /bin/sh -c "gnome-calculator || xcalc || ( type bc >/dev/null 2>&1 && xterm -e bc -l)"
