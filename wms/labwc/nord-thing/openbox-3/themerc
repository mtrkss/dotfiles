### WINDOW
border.width: 2

window.client.padding.width: 0
window.client.padding.height: 0
window.handle.width: 0

padding.width: 4
padding.height: 4

window.active.border.color: #2f343f
window.inactive.border.color: #2f343f
window.active.title.separator.color: #2f343f
window.inactive.title.separator.color: #2f343f
window.active.client.color: #2f343f
window.inactive.client.color: #282b30

window.active.label.text.color: #282b30
window.inactive.label.text.color: #c8c8ee

window.active.button.unpressed.image.color: #282b30
window.inactive.button.unpressed.image.color: #dcd6e4

window.active.title.bg.color: #c8c8ee
window.active.label.bg.color: #282b30
window.inactive.title.bg.color: #282b30
window.inactive.label.bg.color: #D0C2B7

window.inactive.button.unpressed.bg: #ff0000
window.inactive.button.pressed.bg: #ff0000
window.inactive.button.hover.bg: #ff0000
window.inactive.button.disabled.bg: #ff0000
window.inactive.button.toggled.unpressed.bg: #ff0000
window.inactive.button.toggled.pressed.bg: #ff0000
window.inactive.button.toggled.hover.bg: #ff0000

window.label.text.justify: center

#window.active.label.text.font: text shadow
#window.inactive.label.text.font: text shadow

### MENU
menu.separator.width: 1
menu.separator.padding.width: 10
menu.separator.padding.height: 2

menu.separator.color: #eedcb9

menu.title.text.color: #ffffff
menu.items.text.color: #dcd6e4
menu.items.disabled.text.color: #8486a4
menu.items.active.text.color: #282b30
menu.items.active.disabled.text.color: #8486a4

menu.items.bg.color: #282b30
menu.items.active.bg.color: #c8c8ee
menu.title.bg.color: #dcd6e4

menu.title.text.justify: center
